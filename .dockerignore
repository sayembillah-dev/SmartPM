# Dependencies installed inside the image, not copied from your machine
node_modules

# Logs and local junk
npm-debug.log
*.log

# Git and editor files
.git
.gitignore
.vscode

# Secrets — NEVER bake these into an image
.env
*.pem
.env.local

# Docker files themselves don't need to go inside the image
Dockerfile
docker-compose.yml
.dockerignore

